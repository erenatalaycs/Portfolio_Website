{
  "name": "portfolio-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run parity && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "encode-email": "node scripts/encode-email.mjs",
    "parity": "node scripts/check-parity.mjs",
    "size": "size-limit",
    "size:why": "size-limit --why"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "~5.2.8",
    "@gsap/react": "~2.1.2",
    "@mdx-js/react": "~3.1.1",
    "@react-three/drei": "~10.7.7",
    "@react-three/fiber": "~9.6.1",
    "@react-three/postprocessing": "~3.0.4",
    "gsap": "~3.15.0",
    "react": "~19.2.5",
    "react-dom": "~19.2.5",
    "three": "~0.184.0"
  },
  "devDependencies": {
    "@mdx-js/rollup": "~3.1.1",
    "@size-limit/preset-app": "~12.1.0",
    "@tailwindcss/vite": "~4.2.4",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/jest-dom": "~6.9.1",
    "@testing-library/react": "~16.3.2",
    "@types/node": "~25.6.0",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "~6.0.1",
    "@vitest/coverage-v8": "~3.2.4",
    "eslint": "~9.39.4",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-jsx-a11y": "~6.10.2",
    "eslint-plugin-react-hooks": "~7.1.1",
    "eslint-plugin-react-refresh": "~0.5.2",
    "globals": "~17.6.0",
    "jsdom": "~29.1.1",
    "prettier": "~3.8.3",
    "rehype-pretty-code": "~0.14.3",
    "remark-frontmatter": "~5.0.0",
    "remark-gfm": "~4.0.1",
    "remark-mdx-frontmatter": "~5.2.0",
    "shiki": "~4.0.2",
    "size-limit": "~12.1.0",
    "tailwindcss": "~4.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.59.2",
    "vite": "~8.0.10",
    "vitest": "~3.2.4"
  },
  "size-limit": [
    {
      "name": "text shell (initial bundle, gzipped)",
      "path": "dist/assets/index-*.js",
      "limit": "120 KB",
      "gzip": true
    },
    {
      "name": "3D chunk (lazy-loaded, gzipped)",
      "path": "dist/assets/ThreeDShell-*.js",
      "limit": "450 KB",
      "gzip": true
    },
    {
      "name": "GLB workstation desk (Phase 4)",
      "path": "public/assets/workstation/desk.glb",
      "limit": "1000 KB",
      "gzip": false,
      "brotli": false
    },
    {
      "name": "GLB workstation lamp (Phase 4)",
      "path": "public/assets/workstation/lamp.glb",
      "limit": "500 KB",
      "gzip": false,
      "brotli": false
    },
    {
      "name": "GLB workstation bookshelf (Phase 4)",
      "path": "public/assets/workstation/bookshelf.glb",
      "limit": "500 KB",
      "gzip": false,
      "brotli": false
    },
    {
      "name": "Postprocessing chunk (lazy, gzipped)",
      "path": "dist/assets/PostFX-*.js",
      "limit": "100 KB",
      "gzip": true
    }
  ]
}
