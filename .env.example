# Web3Forms (CTC-01) — copy this to .env.local for local dev.
# The key is PUBLIC by design (Web3Forms identifies the form, not authenticates).
# In CI/Production: set as a repo Variable in Settings → Secrets and variables →
# Actions → Variables. Vite statically replaces import.meta.env.VITE_* at build.
VITE_WEB3FORMS_KEY=
VITE_FORM_ENDPOINT=https://api.web3forms.com/submit
